# General Settings
LOG_LEVEL=info
TIMEOUT=30s
MAX_RETRIES=3

# Concurrency Settings
CONCURRENCY_MAX_WORKERS=10
CONCURRENCY_BROWSER_WORKERS=3
CONCURRENCY_API_WORKERS=7

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_SECOND=10

# Storage Configuration
STORAGE_TYPE=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=craowl
POSTGRES_USER=craowl
POSTGRES_PASSWORD=

# Cache Configuration
CACHE_TYPE=redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL=3600

# Proxy Configuration
PROXY_ENABLED=false
PROXY_URL=
PROXY_ROTATION=false

# Platform Specific Settings: Shopee
SHOPEE_ENABLED=true
SHOPEE_BASE_URL=https://shopee.co.id
SHOPEE_RATE_LIMIT=100
SHOPEE_TIMEOUT=30s
SHOPEE_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
